{
  "$comment": "Three-layer perf gate (DECISIONS 2026-07-19, operator-approved). Layer 1: deterministic byte/count budgets — exact, zero-variance, the primary regression tripwires; values = measured 2026-07-19 baselines + headroom (see DECISIONS for the baseline table). Layer 2: statistical metrics asserted on the MEDIAN of 3 runs — thresholds unchanged; aggregationMethod is set explicitly because the LHCI default ('optimistic' = best-of-N) would silently weaken the gate. Layer 3 (escalation rule) lives in DECISIONS. Budgets only tighten without operator approval — loosening one is a flagged, operator-gated change.",
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/styleguide/index.html",
        "http://localhost/services/index.html",
        "http://localhost/about/index.html",
        "http://localhost/services/wrinkle-relaxers/index.html",
        "http://localhost/services/hormone-optimization/index.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "skipAudits": ["is-crawlable"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:accessibility": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:seo": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:best-practices": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "largest-contentful-paint": [
          "error",
          { "maxNumericValue": 2500, "aggregationMethod": "median" }
        ],
        "cumulative-layout-shift": [
          "error",
          { "maxNumericValue": 0.1, "aggregationMethod": "median" }
        ],
        "total-blocking-time": ["error", { "maxNumericValue": 200, "aggregationMethod": "median" }],
        "resource-summary:script:size": [
          "error",
          { "maxNumericValue": 30720, "aggregationMethod": "median" }
        ],
        "resource-summary:third-party:count": [
          "error",
          { "maxNumericValue": 0, "aggregationMethod": "median" }
        ],
        "resource-summary:total:size": [
          "error",
          { "maxNumericValue": 358400, "aggregationMethod": "median" }
        ],
        "resource-summary:image:size": [
          "error",
          { "maxNumericValue": 245760, "aggregationMethod": "median" }
        ],
        "resource-summary:font:size": [
          "error",
          { "maxNumericValue": 122880, "aggregationMethod": "median" }
        ],
        "resource-summary:font:count": [
          "error",
          { "maxNumericValue": 4, "aggregationMethod": "median" }
        ],
        "resource-summary:stylesheet:size": [
          "error",
          { "maxNumericValue": 16384, "aggregationMethod": "median" }
        ],
        "resource-summary:document:size": [
          "error",
          { "maxNumericValue": 16384, "aggregationMethod": "median" }
        ]
      }
    }
  }
}
