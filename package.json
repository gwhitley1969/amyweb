{
  "name": "needlegirlie-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "needlegirlie.com — static Astro site for Needle Girlie (Amy Palacios, FNP)",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/generate-swa-config.mjs",
    "check": "astro check",
    "lint:claims": "node scripts/lint-claims.mjs --self-test && node scripts/lint-claims.mjs",
    "check:approvals": "node scripts/check-approvals.mjs --self-test && node scripts/check-approvals.mjs",
    "test:a11y": "node scripts/test-a11y.mjs",
    "test:perf": "node scripts/test-perf.mjs",
    "verify": "npm run build && npm run check && npm run lint:claims && npm run test:a11y && npm run test:perf"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@lhci/cli": "^0.15.0",
    "@tailwindcss/vite": "^4.0.0",
    "pa11y-ci": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
