---
import { siteConfig } from '../lib/siteConfig';

/**
 * Conversion CTA (BUILD_SPEC §5/§6/§9). The variant enforces the site-wide
 * language convention: "appointment" = booking, "consultation" = clinical
 * routing. Analytics are declarative data-event attributes (§11 event
 * names) read by Phase D's cookieless script — no JS ships now.
 */
interface Props {
  variant: 'book' | 'consult' | 'call';
  href?: string;
  /** Override sparingly — defaults keep the §6 language convention. */
  label?: string;
}

const { variant, href, label } = Astro.props;

const defaults: Record<
  Props['variant'],
  { label: string; href: string; event?: string; style: 'solid' | 'outline' }
> = {
  book: {
    /* "Book with Amy" (client, 2026-07-18) — conversion language, Amy-
     * singular. The §6 convention still governs prose: "appointment" =
     * booking contexts, "consultation" = clinical routing. */
    label: 'Book with Amy',
    href: siteConfig.booking.vagaroUrl,
    event: 'book_click',
    style: 'solid',
  },
  consult: {
    label: 'Request a consultation',
    href: '/book',
    style: 'outline',
  },
  call: {
    label: `Call ${siteConfig.phone}`,
    href: siteConfig.phoneTel,
    event: 'call_click',
    style: 'outline',
  },
};

const cfg = defaults[variant];
const finalHref = href ?? cfg.href;
const external = /^https?:/i.test(finalHref);
---

<a
  href={finalHref}
  class:list={['cta', cfg.style === 'solid' ? 'cta--solid' : 'cta--outline']}
  data-event={cfg.event}
  {...external ? { target: '_blank', rel: 'noopener' } : {}}
>
  {label ?? cfg.label}
  {/* plain punctuation chevron — explicitly NOT the signature motif;
      nudges on hover (the sanctioned third motion move) */}
  <span class="chev-nudge" aria-hidden="true">&rsaquo;</span>
  {external && <span class="sr-only">(opens in new tab)</span>}
</a>

<style is:global>
  /* Squared editorial corners ("serious glamour", DECISIONS 2026-07-18) —
   * the pill retired with the playful register. */
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 3rem; /* WCAG 2.2 target size with room to spare */
    padding: 0.75rem 1.5rem;
    border-radius: 2px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
  }
  /* Solid fills are BRAND PINK with ink text (4.88:1, tokens.css — client
   * round 2026-07-18). White text on pink/magenta fills remains banned
   * (fails the 4.7 headroom bar); the pink is legal only under ink-900. */
  .cta--solid {
    background: var(--ng-pink-500);
    color: var(--ng-ink-900);
  }
  .cta--solid:hover {
    /* brighten toward pink-300 — 6.08:1 with ink text (verified) */
    background: color-mix(in srgb, var(--ng-pink-300) 35%, var(--ng-pink-500));
  }
  .cta--outline {
    border: 1px solid var(--ng-link);
    color: var(--ng-link);
  }
  .cta--outline:hover {
    background: color-mix(in srgb, var(--ng-link) 10%, transparent);
  }
</style>
