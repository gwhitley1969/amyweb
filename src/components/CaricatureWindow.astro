---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Arched portrait window — the brand's frame for a portrait/illustration
 * moment. Hairline pink border; on noir it carries a soft STATIC neon
 * halo (the sign is the only thing that animates — adjacency rule,
 * docs/DECISIONS.md 2026-07-08). `taped` straps two caution-tape strips
 * across the lower third for construction contexts; Phase C reuse
 * (e.g. an About portrait) omits it.
 */
interface Props {
  image: ImageMetadata;
  alt: string;
  taped?: boolean;
  class?: string;
}

const { image, alt, taped = false, class: className } = Astro.props;
---

<figure class:list={['caricature-window', className]}>
  <div class="cw-frame">
    <Image
      src={image}
      alt={alt}
      widths={[360, 520, 780, 1040]}
      sizes="(max-width: 640px) 86vw, 520px"
      loading="eager"
    />
  </div>
  {
    taped && (
      <>
        <div class="cw-tape cw-tape-upper" aria-hidden="true" />
        <div class="cw-tape cw-tape-lower" aria-hidden="true" />
      </>
    )
  }
</figure>

<style is:global>
  /* is:global because the noir scope lives on an ancestor outside this
   * component (same pattern as ChevronRun). All selectors are cw-*
   * namespaced. */
  .caricature-window {
    position: relative;
    margin: 0 auto;
  }
  .cw-frame {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--ng-pink-300) 50%, transparent);
    border-radius: 999px 999px 16px 16px;
  }
  .cw-frame img {
    display: block;
    width: 100%;
    height: auto;
  }
  /* Neon-500, noir-only, per the token usage rules — and static. */
  [data-surface='noir'] .cw-frame {
    box-shadow: 0 0 34px color-mix(in srgb, var(--ng-neon-500) 22%, transparent);
  }
  .cw-tape {
    position: absolute;
    height: clamp(1rem, 4vw, 1.375rem);
    width: 72%;
    border-top: 1px solid var(--ng-pink-300);
    border-bottom: 1px solid var(--ng-pink-300);
    background: repeating-linear-gradient(
      45deg,
      var(--ng-pink-500),
      var(--ng-pink-500) 20px,
      var(--ng-noir) 20px,
      var(--ng-noir) 40px
    );
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.55);
  }
  .cw-tape-upper {
    bottom: 13%;
    left: -6%;
    transform: rotate(-7deg);
  }
  .cw-tape-lower {
    bottom: 4%;
    right: -6%;
    transform: rotate(5deg);
  }
</style>
