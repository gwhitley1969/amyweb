---
import { Image } from 'astro:assets';
import wordmark from '../assets/brand/needle-girlie-wordmark-alpha.png';
import GetTheApp from './GetTheApp.astro';
import { siteConfig } from '../lib/siteConfig';

/**
 * Noir footer — the closing bookend (approved design plan). NAP from
 * siteConfig only; social links render once {{SOCIAL_LINKS}} resolves.
 */
const legal = [
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
  { label: 'Medical disclaimer', href: '/medical-disclaimer' },
];
const year = new Date().getFullYear();
const socialEntries = Object.entries(siteConfig.social).filter(
  ([, url]) => typeof url === 'string' && !/\{\{.+\}\}/.test(url),
);
---

<div class="surface site-footer" data-surface="noir">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-12 sm:grid-cols-3">
    <div>
      <Image src={wordmark} alt="Needle Girlie" width={160} densities={[1, 2]} />
      <p class="mt-4 text-sm">
        {siteConfig.legalName}<br />
        {siteConfig.address}
      </p>
      <p class="mt-2 text-sm">
        <a href={siteConfig.phoneTel} data-event="call_click" class="footer-link">
          {siteConfig.phone}
        </a>
      </p>
    </div>
    <div>
      <h2 class="eyebrow">Legal</h2>
      <ul class="mt-3 space-y-2 text-sm">
        {
          legal.map((item) => (
            <li>
              <a href={item.href} class="footer-link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      {
        socialEntries.length > 0 && (
          <ul class="mt-4 flex gap-2" role="list" aria-label="Amy on social media">
            {socialEntries.map(([name, url]) => (
              <li>
                <a
                  href={String(url)}
                  target="_blank"
                  rel="noopener"
                  class="footer-social"
                  aria-label={`${name.charAt(0).toUpperCase()}${name.slice(1)} (opens in new tab)`}
                >
                  {/* Monochrome marks, stroke/fill = currentColor (link token). */}
                  <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" fill="none">
                    {name === 'facebook' && (
                      <path
                        fill="currentColor"
                        d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12Z"
                      />
                    )}
                    {name === 'instagram' && (
                      <>
                        <rect
                          x="2.5"
                          y="2.5"
                          width="19"
                          height="19"
                          rx="5"
                          stroke="currentColor"
                          stroke-width="1.8"
                        />
                        <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8" />
                        <circle cx="17.3" cy="6.7" r="1.3" fill="currentColor" />
                      </>
                    )}
                    {name === 'yelp' && (
                      <>
                        <circle cx="12" cy="12" r="9.5" stroke="currentColor" stroke-width="1.8" />
                        <path
                          d="M8.2 7.2 12 12m3.8-4.8L12 12m0 0v5.4"
                          stroke="currentColor"
                          stroke-width="1.8"
                          stroke-linecap="round"
                        />
                      </>
                    )}
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
    <div>
      <GetTheApp />
    </div>
  </div>
  <div class="mx-auto max-w-6xl px-6 pb-8 text-sm">
    <p>© {year} Needle Girlie. All rights reserved.</p>
    <p class="mt-2 text-xs">
      Created by: <a
        href="https://xtend-ai.com"
        class="footer-link"
        target="_blank"
        rel="noopener"
        aria-label="Xtend-AI (opens in new tab)">Xtend-AI</a>
    </p>
  </div>
</div>

<style is:global>
  .site-footer {
    border-top: 1px solid var(--ng-hairline);
  }
  .footer-link {
    color: var(--ng-link);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  /* Social marks: comfortable tap targets (WCAG 2.2), link-token color. */
  .footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.75rem;
    min-height: 2.75rem;
    color: var(--ng-link);
  }
  .footer-social:hover {
    color: var(--ng-text);
  }
</style>
