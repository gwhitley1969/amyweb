---
import { Image } from 'astro:assets';
import wordmark from '../assets/brand/needle-girlie-wordmark-alpha.png';
import GetTheApp from './GetTheApp.astro';
import { siteConfig } from '../lib/siteConfig';

/**
 * Noir footer — the closing bookend (approved design plan). NAP from
 * siteConfig only; social links render once {{SOCIAL_LINKS}} resolves.
 */
const legal = [
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
  { label: 'Medical disclaimer', href: '/medical-disclaimer' },
];
const year = new Date().getFullYear();
const socialEntries = Object.entries(siteConfig.social).filter(
  ([, url]) => typeof url === 'string' && !/\{\{.+\}\}/.test(url),
);
---

<div class="surface site-footer" data-surface="noir">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-12 sm:grid-cols-3">
    <div>
      <Image src={wordmark} alt="Needle Girlie" width={160} densities={[1, 2]} />
      <p class="mt-4 text-sm">
        {siteConfig.legalName}<br />
        {siteConfig.address}
      </p>
      <p class="mt-2 text-sm">
        <a href={siteConfig.phoneTel} data-event="call_click" class="footer-link">
          {siteConfig.phone}
        </a>
      </p>
    </div>
    <div>
      <h2 class="heading-4">Legal</h2>
      <ul class="mt-3 space-y-2 text-sm">
        {
          legal.map((item) => (
            <li>
              <a href={item.href} class="footer-link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      {
        socialEntries.length > 0 && (
          <ul class="mt-4 flex gap-4">
            {socialEntries.map(([name, url]) => (
              <li>
                <a href={String(url)} target="_blank" rel="noopener" class="footer-link">
                  {name}
                  <span class="sr-only">(opens in new tab)</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
    <div>
      <GetTheApp />
    </div>
  </div>
  <div class="mx-auto max-w-6xl px-6 pb-8 text-sm">
    <p>© {year} Needle Girlie. All rights reserved.</p>
  </div>
</div>

<style is:global>
  .site-footer {
    border-top: 1px solid color-mix(in srgb, var(--ng-pink-300) 25%, transparent);
  }
  .footer-link {
    color: var(--ng-link);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
