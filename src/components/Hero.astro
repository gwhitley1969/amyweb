---
import { Image } from 'astro:assets';
import lockup from '../assets/brand/needle-girlie-lockup-alpha.png';

/**
 * The neon sign (approved design plan): noir surface, glowing lockup, the
 * page h1 as visible text (the promise), CTAs via slot. The lockup image
 * is decorative-adjacent brand art; the h1 carries the content.
 */
interface Props {
  /** The one-line promise — claim-clean, operator-approved wording. */
  promise: string;
}

const { promise } = Astro.props;
---

<section class="surface" data-surface="noir">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-8 px-6 py-16 text-center">
    {/* Near-full-bleed by design — client direction: "it's got to be big." */}
    <Image
      src={lockup}
      alt="Needle Girlie"
      widths={[480, 800, 1200, 1879]}
      sizes="(max-width: 1100px) 94vw, 1040px"
      class="hero-sign w-full max-w-[1040px]"
      loading="eager"
      fetchpriority="high"
    />
    <h1 class="display-2 text-balance">{promise}</h1>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <slot />
    </div>
  </div>
</section>

<style is:global>
  /* "Turn on the sign": the neon ignites once on load (keyframes +
   * reduced-motion handling in global.css). */
  .hero-sign {
    animation: ng-ignite 1.2s ease-out 1 backwards;
  }
</style>
