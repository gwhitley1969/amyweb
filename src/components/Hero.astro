---
import { Image } from 'astro:assets';
import lockup from '../assets/brand/needle-girlie-lockup-alpha.png';

/**
 * The sign, composed ("serious glamour", DECISIONS 2026-07-18): noir
 * surface, lockup under a STATIC aura — the neon identity held still —
 * the page h1 as visible text (the promise), CTAs via slot. The lockup
 * image is decorative-adjacent brand art; the h1 carries the content.
 */
interface Props {
  /** The one-line promise — claim-clean, operator-approved wording. */
  promise: string;
  /** Optional editorial kicker above the promise (claim-clean). */
  eyebrow?: string;
}

const { promise, eyebrow } = Astro.props;
---

<section class="surface" data-surface="noir">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-8 px-6 py-16 text-center">
    {/* Near-full-bleed by design — client direction: "it's got to be big." */}
    <Image
      src={lockup}
      alt="Needle Girlie"
      widths={[480, 800, 1200, 1879]}
      sizes="(max-width: 1100px) 94vw, 1040px"
      class="ng-aura ng-aura-live w-full max-w-[1040px]"
      loading="eager"
      fetchpriority="high"
    />
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="display-2 text-balance">{promise}</h1>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <slot />
    </div>
  </div>
</section>
