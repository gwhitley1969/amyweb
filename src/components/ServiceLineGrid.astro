---
import TreatmentCard from './TreatmentCard.astro';
import { serviceLines } from '../lib/serviceLines';

/**
 * The 12 service lines (BUILD_SPEC §6 + the 2026-07-19 Vagaro
 * alignment + laser-treatments, 2026-07-22). All-equal by default;
 * which lines lead ("featured") is a Phase C business decision with
 * the operator.
 */
interface Props {
  featuredSlugs?: string[];
}

const { featuredSlugs = [] } = Astro.props;
---

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {
    serviceLines.map((line) => (
      <TreatmentCard
        title={line.title}
        summary={line.summary}
        href={line.href}
        featured={featuredSlugs.includes(line.slug)}
        class="ng-rise"
      />
    ))
  }
</div>
