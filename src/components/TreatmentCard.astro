---
/**
 * Service-line card ("serious glamour" anatomy, client-recolored
 * 2026-07-22): flat brand-pink card on the paper ambient, NO drop shadow,
 * hairline border with a 1px ink-pink edge rule (left), body-sans title.
 * Hover/focus = background deepens (card-hover token) + a 2px ring on
 * all four sides (ring/title color under client trial — see below). No
 * scale/shadow transforms. The link text is the treatment title
 * (descriptive link text, §10).
 */
interface Props {
  title: string;
  summary: string;
  href: string;
  featured?: boolean;
  /** Extra classes (e.g. ng-rise from ServiceLineGrid). */
  class?: string;
}

const { title, summary, href, featured = false, class: className } = Astro.props;
---

<article class:list={['treatment-card', featured && 'treatment-card--featured', className]}>
  <h3 class="heading-4">
    <a href={href} class="treatment-card__link">
      {title}
      <span class="chev-nudge" aria-hidden="true">&rsaquo;</span>
    </a>
  </h3>
  <p class="mt-2">{summary}</p>
</article>

<style is:global>
  .treatment-card {
    position: relative;
    background: var(--ng-card-rest);
    border: 1px solid var(--ng-hairline);
    border-left: 1px solid var(--ng-ink-pink);
    padding: 1.5rem;
    transition:
      background-color 150ms ease,
      border-color 150ms ease,
      box-shadow 150ms ease;
  }
  .treatment-card:hover,
  .treatment-card:focus-within {
    background: var(--ng-card-hover);
    /* CLIENT TRIAL 2026-07-22 (round 3) — NOT production-cleared: the
     * logo-lips neon (--ng-neon-500) as ring + title letters measures
     * 2.10:1 on the #efb1d5 highlight bg (WCAG AA needs 3:1 for both),
     * and the token's own rule says neon never renders as text. Ships
     * only with a recorded operator override; verified fallback is
     * var(--ng-ink-pink) (3.81:1). */
    border-color: var(--ng-neon-500);
    /* 2px ring on all four sides, no layout shift */
    box-shadow: inset 0 0 0 1px var(--ng-neon-500);
  }
  .treatment-card__link {
    color: var(--ng-ink-900);
    text-decoration: none;
  }
  .treatment-card__link:hover {
    /* CLIENT TRIAL 2026-07-22 (round 3) — see the ring note above; same
     * failing pair, same override requirement. */
    color: var(--ng-neon-500);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  /* stretch the card's click target to the whole card */
  .treatment-card__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .treatment-card--featured {
    grid-column: span 2;
  }
  @media (max-width: 640px) {
    .treatment-card--featured {
      grid-column: span 1;
    }
  }
</style>
