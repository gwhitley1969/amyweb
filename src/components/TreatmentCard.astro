---
/**
 * Service-line card — the editorial-menu anatomy (client direction
 * 2026-07-23, supersedes the body-sans anatomy): flat brand-pink plate on
 * the paper ambient, NO drop shadow, hairline border with a 1px ink-pink
 * edge rule (left), oversized Playfair index numeral, Playfair title,
 * sans summary, "See the line ›" microline pinned to the card foot.
 * Hover/focus = plate deepens (card-hover token) + a 2px ink-pink ring on
 * all four sides + title in ink-pink + a 2px ink-pink rule draws across
 * the card top (the ng-trace signature at card scale). No scale/shadow
 * transforms. The link text is the treatment title (descriptive link
 * text, §10); the numeral is decorative (aria-hidden) but still passes
 * large-text contrast (ink-pink 4.60:1 on card-rest, house bar 3.2).
 * The microline is ink-900, NOT ink-pink: at 13px it is body-size text,
 * and ink-pink holds only 3.81:1 on the #efb1d5 hover plate (4.5 hard
 * bar); ink-900 holds 9.77:1 there (tokens.css CLIENT CARD PINKS table).
 */
interface Props {
  title: string;
  summary: string;
  href: string;
  /** 1-based menu position; renders as the 01–12 numeral when present. */
  index?: number;
  featured?: boolean;
  /** Extra classes (e.g. ng-rise from ServiceLineGrid). */
  class?: string;
}

const { title, summary, href, index, featured = false, class: className } = Astro.props;
const numeral = index === undefined ? undefined : String(index).padStart(2, '0');
---

<article class:list={['treatment-card', featured && 'treatment-card--featured', className]}>
  {numeral && (
    <span class="treatment-card__num" aria-hidden="true">
      {numeral}
    </span>
  )}
  <h3 class="treatment-card__title">
    <a href={href} class="treatment-card__link">{title}</a>
  </h3>
  <p class="mt-3">{summary}</p>
  <p class="treatment-card__more">
    See the line
    <span class="chev-nudge" aria-hidden="true">&rsaquo;</span>
  </p>
</article>

<style is:global>
  .treatment-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--ng-card-rest);
    border: 1px solid var(--ng-hairline);
    border-left: 1px solid var(--ng-ink-pink);
    padding: 2rem;
    transition:
      background-color 150ms ease,
      border-color 150ms ease,
      box-shadow 150ms ease;
  }
  /* The drawn top rule — ng-trace's draw-in, replayed at card scale on
   * pointer instead of scroll. Empty non-text pseudo (same class of thing
   * as the link overlay below — safe for the axe gate). */
  .treatment-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--ng-ink-pink);
    scale: 0 1;
    transform-origin: left center;
    transition: scale 250ms ease;
  }
  .treatment-card:hover,
  .treatment-card:focus-within {
    background: var(--ng-card-hover);
    /* client pick 2026-07-22 (round 4, back to the round-1 berry):
     * ink-pink ring + title letters — 3.81:1 on the #efb1d5 highlight
     * bg, passes AA (3.0 non-text / 3.2 house large-text). See the
     * tokens.css header table. */
    border-color: var(--ng-ink-pink);
    /* 2px ring on all four sides, no layout shift */
    box-shadow: inset 0 0 0 1px var(--ng-ink-pink);
  }
  .treatment-card:hover::before,
  .treatment-card:focus-within::before {
    scale: 1 1;
  }
  .treatment-card__num {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3rem);
    font-weight: 500;
    line-height: 1;
    font-variant-numeric: lining-nums;
    color: var(--ng-ink-pink);
  }
  .treatment-card__title {
    margin-top: 1rem;
    font-family: var(--font-display);
    font-size: clamp(1.5625rem, 2.5vw, 1.9375rem);
    font-weight: 500;
    line-height: 1.2;
  }
  .treatment-card__link {
    color: var(--ng-ink-900);
    text-decoration: none;
  }
  .treatment-card__link:hover {
    /* same passing pair as the ring above */
    color: var(--ng-ink-pink);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  /* stretch the card's click target to the whole card */
  .treatment-card__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .treatment-card__more {
    margin-top: auto;
    padding-top: 1.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ng-ink-900);
  }
  .treatment-card__more .chev-nudge {
    color: var(--ng-ink-pink);
    font-size: 1.2em;
    line-height: 1;
  }
  .treatment-card--featured {
    grid-column: span 2;
  }
  @media (max-width: 640px) {
    .treatment-card--featured {
      grid-column: span 1;
    }
  }
</style>
