---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Self-hosted treatment film (first used on /services/dermal-fillers —
 * operator decisions recorded in docs/DECISIONS.md, 2026-07-21).
 * Click-to-play only: `preload="none"` keeps the file out of the page
 * budget entirely until the visitor asks for it, the poster carries the
 * visual, and native controls mean zero client-side JavaScript. No
 * autoplay, so no reduced-motion or pause obligations arise. The captions
 * track is required — the a11y gate (axe video-caption) fails without it.
 * Media files live in public/media/ (same-origin; CSP default-src covers
 * them; cache route in config/swa/).
 */
interface Props {
  /** Public path to the MP4, e.g. "/media/evolysse-film.mp4". */
  src: string;
  /** Poster frame — processed through astro:assets. */
  poster: ImageMetadata;
  /** Public path to the WebVTT captions file. */
  captionsSrc: string;
  /** Accessible name for the video element. */
  label: string;
  /** Optional printed caption under the frame. */
  caption?: string;
}

const { src, poster, captionsSrc, label, caption } = Astro.props;

const posterImg = await getImage({ src: poster, width: 1280, format: 'webp' });
---

<figure class="video-figure">
  <video
    controls
    preload="none"
    playsinline
    width={poster.width}
    height={poster.height}
    poster={posterImg.src}
    aria-label={label}
  >
    <source src={src} type="video/mp4" />
    <track kind="captions" src={captionsSrc} srclang="en" label="English" default />
    Your browser doesn't support embedded video — <a href={src}>download the film</a> instead.
  </video>
  {caption && <figcaption class="eyebrow">{caption}</figcaption>}
</figure>

<style>
  /* Framed like the media-row prints (paper mat + hairline + lift), but
   * straight — a tilted frame reads wrong on an interactive element. */
  .video-figure {
    margin-top: 2.5rem;
    background: var(--ng-paper);
    border: 1px solid var(--ng-hairline);
    padding: 0.625rem;
    box-shadow: 0 14px 28px -16px color-mix(in srgb, var(--ng-ink-900) 40%, transparent);
  }
  .video-figure video {
    display: block;
    width: 100%;
    height: auto;
    background: var(--ng-ink-900);
  }
  .video-figure figcaption {
    margin-top: 0.5rem;
    text-align: center;
  }
</style>
