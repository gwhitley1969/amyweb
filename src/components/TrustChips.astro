---
import { siteConfig } from '../lib/siteConfig';

/**
 * Factual reassurance line shown at conversion points (adopted from the
 * Mobbin review, docs/DECISIONS.md; pills retired for an editorial
 * middot-separated credential line — "serious glamour", 2026-07-18).
 * Credentials and process facts ONLY — never outcome, safety, or
 * superiority language (§8). Text color rides the surface-scoped link
 * token, so the line passes 4.5:1 on both surfaces (ink-pink on light
 * 6.71:1, pink-300 on noir 11.58:1 — tokens.css).
 */
/* "Free consultation upon request" is operator-confirmed business fact
 * (2026-07-18): Amy does not require consultations — they are optional
 * and free. The old "Consultation-first" framing is retired sitewide. */
const chips = ['Licensed nurse practitioner', 'Free consultation upon request', siteConfig.locality];
---

<ul class="trust-chips" role="list" aria-label="About the practice">
  {chips.map((c) => <li class="trust-chips__chip">{c}</li>)}
</ul>

<style is:global>
  .trust-chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: 0.75rem;
    row-gap: 0.375rem;
    list-style: none;
    padding: 0;
  }
  .trust-chips__chip {
    color: var(--ng-link);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  /* Editorial middot separators (decorative punctuation). */
  .trust-chips__chip + .trust-chips__chip::before {
    content: '\00B7';
    margin-right: 0.75rem;
    opacity: 0.6;
  }
</style>
