---
import { siteConfig } from '../lib/siteConfig';

/**
 * Factual reassurance chips shown at conversion points (adopted from the
 * Mobbin review, docs/DECISIONS.md). Credentials and process facts ONLY —
 * never outcome, safety, or superiority language (§8). Text color rides
 * the surface-scoped link token, so the chips pass 4.5:1 on both surfaces
 * (ink-pink on light 6.71:1, pink-300 on noir 11.58:1 — tokens.css).
 */
const chips = ['Licensed nurse practitioner', 'Consultation-first', siteConfig.locality];
---

<ul class="trust-chips" role="list" aria-label="About the practice">
  {chips.map((c) => <li class="trust-chips__chip">{c}</li>)}
</ul>

<style is:global>
  .trust-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }
  .trust-chips__chip {
    color: var(--ng-link);
    border: 1px solid color-mix(in srgb, var(--ng-link) 50%, transparent);
    border-radius: 9999px;
    padding: 0.25rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 600;
  }
</style>
