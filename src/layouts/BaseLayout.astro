---
import '@fontsource-variable/playfair-display';
import '@fontsource-variable/dm-sans';
import playfairWoff2 from '@fontsource-variable/playfair-display/files/playfair-display-latin-wght-normal.woff2?url';
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import { localBusiness } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  /** Page surface: light "studio" (default — wears the site-wide ombre
   * canvas since 2026-07-23, client-approved) or dark "sign"
   * (BUILD_SPEC §5). The ombre is styled off this surface in
   * global.css; there is no per-page opt-out. */
  surface?: 'light' | 'noir';
  ogImage?: string | undefined;
  /** Page-specific JSON-LD objects (§10) rendered after the sitewide
   * LocalBusiness — built only via src/lib/schema.ts builders. */
  jsonLd?: object[];
}

const { title, description, surface = 'light', ogImage, jsonLd: pageJsonLd = [] } = Astro.props;
const jsonLd = JSON.stringify(localBusiness());
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead title={title} description={description} ogImage={ogImage} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    {/* Display face only (§13: preload the display weight); DM Sans relies on swap + metric fallbacks. */}
    <link rel="preload" href={playfairWoff2} as="font" type="font/woff2" crossorigin />
    <script type="application/ld+json" set:html={jsonLd} />
    {pageJsonLd.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}
  </head>
  <body
    class="min-h-dvh"
    data-surface={surface === 'noir' ? 'noir' : undefined}
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-white focus:p-3 focus:text-black focus:underline"
    >
      Skip to content
    </a>
    <header>
      <slot name="header" />
    </header>
    <main id="main">
      <slot />
    </main>
    <footer>
      <slot name="footer" />
    </footer>
  </body>
</html>
