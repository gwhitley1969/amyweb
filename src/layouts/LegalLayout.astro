---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DraftBanner from '../components/DraftBanner.astro';

/**
 * Legal-page template (§6, Phase C7). Every legal page renders the
 * visible counsel-review DraftBanner until counsel signs off — same
 * conspicuousness principle as the clinician banner. Voice: legal pages
 * speak in the third person ("Needle Girlie", "this website") — the
 * Amy-singular convention and lint:voice still apply.
 */
interface Props {
  heading: string;
  title: string;
  description: string;
}

const { heading, title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="header">
    <DraftBanner label="Draft — pending counsel review" />
    <Header />
  </Fragment>

  <article class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <p class="eyebrow">Legal</p>
    <hr class="rule-accent mt-4" aria-hidden="true" />
    <h1 class="display-2 mt-6">{heading}</h1>
    <p class="mt-4 text-sm">
      Draft dated July 19, 2026. An effective date will be set when this
      page is finalized.
    </p>
    <div class="legal-body mt-8">
      <slot />
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style is:global>
  .legal-body h2 {
    font-family: var(--font-body);
    font-size: 1.5625rem;
    line-height: 1.3;
    font-weight: 600;
    margin-top: 2.5rem;
  }
  .legal-body p,
  .legal-body ul {
    margin-top: 0.75rem;
    max-width: 65ch;
  }
  .legal-body ul {
    list-style: disc;
    padding-left: 1.5rem;
  }
  .legal-body a {
    color: var(--ng-link);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
