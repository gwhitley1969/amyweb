---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTAButton from '../components/CTAButton.astro';
import DisclaimerBlock from '../components/DisclaimerBlock.astro';
import InvestigationalNotice from '../components/InvestigationalNotice.astro';
import BioteDisclaimer from '../components/BioteDisclaimer.astro';
import DraftBanner from '../components/DraftBanner.astro';
import ProductDetailCards from '../components/ProductDetailCards.astro';
import VisitSteps from '../components/VisitSteps.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import TrustChips from '../components/TrustChips.astro';

/**
 * Treatment page template (approved design plan + Mobbin-review addendum).
 * The compliance order is FIXED here — pages cannot reorder or opt out
 * (CLAUDE.md hard constraint 3):
 *   breadcrumbs -> H1 + underline run -> lead -> deck statement card
 *   (optional; replaced AtAGlance 2026-07-20, operator direction) ->
 *   intro -> products -> flag-driven notices ADJACENT to products -> body ->
 *   visit steps -> FAQ (only when items provided) -> pricing ->
 *   consult router -> DisclaimerBlock (light surface, NEVER collapsed) ->
 *   seam -> noir CTA band + trust chips.
 */
interface Props {
  title: string;
  summary: string;
  /** Editorial standfirst — one short, claims-clean display line shown
   * as the blush statement card under the lead. */
  deck?: string;
  products: string[];
  ctaType: 'book' | 'consult' | 'shop';
  investigational: boolean;
  bioteDisclaimer: boolean;
  pricingDisplay: 'none' | 'consult' | 'startingAt';
  clinicianApproved: boolean;
  investigationalProduct?: string;
  /** When provided, renders ProductDetailCards in place of the products
   * bullet list — same slot in the fixed compliance order. */
  productDetails?: readonly {
    name: string;
    detail: string;
    tag?: string;
    priceLines?: readonly string[];
  }[];
  /** Editorial Q&A only — compliance text never goes in an accordion. */
  faq?: { q: string; a: string }[];
  seo: { title: string; description: string };
  /** Page JSON-LD (service + breadcrumbs) built by the route via
   * src/lib/schema.ts — forwarded to BaseLayout untouched. */
  jsonLd?: object[];
}

const {
  title,
  summary,
  deck,
  products,
  ctaType,
  investigational,
  bioteDisclaimer,
  pricingDisplay,
  clinicianApproved,
  investigationalProduct,
  productDetails = [],
  faq = [],
  seo,
  jsonLd = [],
} = Astro.props;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: title, href: Astro.url.pathname },
];
---

<BaseLayout title={seo.title} description={seo.description} jsonLd={jsonLd}>
  <Fragment slot="header">
    {!clinicianApproved && <DraftBanner />}
    <Header />
  </Fragment>

  <article class="mx-auto max-w-3xl px-6 py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="heading-2 md:display-2 mt-6">{title}</h1>
    <hr class="rule-accent mt-4" />
    <p class="lead mt-6">{summary}</p>

    {deck && <p class="deck mt-8">{deck}</p>}

    <slot name="intro" />

    {
      productDetails.length > 0 ? (
        <>
          <h2 class="heading-3 mt-10">What Amy offers</h2>
          <ProductDetailCards items={productDetails} />
        </>
      ) : (
        products.length > 0 && (
          <>
            <h2 class="heading-3 mt-10">What Amy offers</h2>
            <ul class="mt-3 list-disc space-y-1 pl-6">
              {products.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          </>
        )
      )
    }

    {/* Disclosures sit ADJACENT to the products they qualify — never below the fold of the copy. */}
    {investigational && <InvestigationalNotice productName={investigationalProduct} />}
    {bioteDisclaimer && <BioteDisclaimer />}

    <div class="treatment-body">
      <slot />
    </div>

    <div class="mt-12">
      <VisitSteps />
    </div>

    {
      faq.length > 0 && (
        <div class="mt-12">
          <FaqAccordion items={faq} />
        </div>
      )
    }

    {
      pricingDisplay === 'consult' && (
        <p class="mt-8">Pricing is individual and discussed during your consultation.</p>
      )
    }

    <div class="router-card mt-10">
      <h2 class="heading-4">The right fit is a conversation.</h2>
      <p class="mt-2">Every plan is personal — decided with Amy, in consultation.</p>
      <div class="mt-4">
        <CTAButton variant="consult" />
      </div>
    </div>

    <DisclaimerBlock />
  </article>

  <div class="surface" data-surface="noir">
    <div class="mx-auto max-w-3xl px-6 py-12">
      <h2 class="heading-2">
        Ready <span class="display-accent ng-shimmer">when you are</span>
      </h2>
      <div class="mt-6">
        {
          ctaType === 'book' ? (
            <CTAButton variant="book" />
          ) : ctaType === 'shop' ? (
            <CTAButton variant="shop" />
          ) : (
            <CTAButton variant="consult" />
          )
        }
      </div>
      <div class="mt-6">
        <TrustChips />
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style is:global>
  .router-card {
    background: var(--ng-card);
    border: 1px solid var(--ng-hairline);
    border-left: 1px solid var(--ng-magenta-600);
    padding: 1.5rem;
  }
  /* Editorial standfirst: the blush "jewelry" card carrying one display
   * line — replaced the AtAGlance fact table (2026-07-20). Upright
   * Playfair only (no italic face is loaded — keeps the font budget
   * untouched); ink-900 on blush 15.77:1, magenta edge 4.15:1 non-text
   * (tokens.css table). */
  .deck {
    background: var(--ng-card);
    border: 1px solid var(--ng-hairline);
    border-left: 2px solid var(--ng-magenta-600);
    padding: 1.5rem 1.75rem;
    font-family: var(--font-display);
    font-size: 1.5625rem;
    line-height: 1.4;
  }
  /* Element styles for MDX body content (C3): headings mirror the
   * heading-3 utility so collection prose sits on the type scale. */
  .treatment-body h2 {
    font-family: var(--font-body);
    font-size: 1.9375rem;
    line-height: 1.25;
    font-weight: 600;
    margin-top: 2.5rem;
  }
  .treatment-body p {
    margin-top: 0.75rem;
    max-width: 65ch;
  }
  /* Editorial media row for MDX bodies: framed-print figure beside copy —
   * echoes the concept page's framed-post motif. Static, zero JS; the
   * astro:assets pipeline sets width/height (no CLS) and lazy-loads. */
  .treatment-body .media-row {
    display: grid;
    gap: 2rem;
    align-items: center;
    margin-top: 2.5rem;
  }
  @media (min-width: 40rem) {
    .treatment-body .media-row {
      grid-template-columns: 2fr 3fr;
    }
  }
  .treatment-body .media-figure {
    justify-self: center;
    width: min(18rem, 100%);
    background: var(--ng-paper);
    border: 1px solid var(--ng-hairline);
    padding: 0.625rem;
    box-shadow: 0 14px 28px -16px color-mix(in srgb, var(--ng-ink-900) 40%, transparent);
    transform: rotate(-1.5deg);
  }
  .treatment-body .media-figure img {
    display: block;
    width: 100%;
    height: auto;
  }
  .treatment-body .media-figure figcaption {
    margin-top: 0.5rem;
    text-align: center;
  }
  .treatment-body .media-copy h2 {
    margin-top: 0;
  }
</style>
