---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTAButton from '../components/CTAButton.astro';
import AtAGlance from '../components/AtAGlance.astro';
import pinkGloves from '../assets/photos/pink-gloves-detail.jpg';

/**
 * /book — single-purpose conversion page (§6, Phase C1). Booking happens
 * on Vagaro; this page explains the handoff and keeps the phone fallback
 * one tap away. Consultation routing here is prose + the call CTA —
 * never the consult CTAButton, whose default href IS this page.
 * Language convention (§6): "appointment" = booking, "consultation" =
 * clinical routing. No closing band by design: every path off this page
 * is book, call, or ask.
 *
 * The portrait is the gloves detail (8K0A1120, operator pick 2026-07-19
 * — replaces the concept-hero frame so /book adds no client-release
 * exposure). No client in frame; the crop cuts the tray signage at the
 * bottom; the Evolus scrubs embroidery remains (open flag, same as the
 * concept). Light-wash grade per the light-band rule — the cinema grade
 * stays on noir bands.
 */
---

<BaseLayout
  title="Book an appointment | Needle Girlie"
  description="Book an appointment with Amy Palacios, FNP in Harrisburg, NC — online through Vagaro, or by phone. A free consultation is available on request."
>
  <Header slot="header" />

  <section class="mx-auto max-w-6xl px-6 pt-16 sm:pt-20">
    <div class="grid items-center gap-10 md:grid-cols-[6fr_5fr]">
      <div>
        <p class="eyebrow">Booking</p>
        <hr class="rule-accent mt-4" aria-hidden="true" />
        <h1 class="display-2 mt-6">Book an appointment</h1>
        <p class="lead mt-6">
          Appointments with Amy are scheduled through Vagaro, an online
          booking site. Choose a service and a time that works for you —
          the button below opens Vagaro in a new tab.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <CTAButton variant="book" />
          <CTAButton variant="call" />
        </div>
      </div>
      <figure class="book-portrait">
        <Image
          src={pinkGloves}
          alt="Amy's pink-gloved hands preparing for a treatment in the studio."
          widths={[480, 760, 1080]}
          sizes="(min-width: 768px) 40vw, 90vw"
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
    <div class="ng-rise">
      <h2 class="heading-3">New to Amy&rsquo;s care?</h2>
      <p class="mt-3 max-w-prose">
        A consultation is never required to book, and one is free on
        request. If you&rsquo;d like to talk through your options before
        choosing a service, ask when you book — or call and request a
        consultation.
      </p>
    </div>
    <div class="mt-10 max-w-xl ng-rise">
      <AtAGlance />
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style is:global>
  /* Editorial portrait frame — hairline border, light-wash grade (the
   * light-band treatment; noir bands keep the cinema grade). The overlay
   * sits on the image only — no text above it (a11y photo rules). */
  .book-portrait {
    position: relative;
    margin: 0;
    border: 1px solid var(--ng-hairline);
    overflow: hidden;
  }
  .book-portrait img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    /* window features the gloved hands and ends above the tray's
     * location signage (same crop discipline as the concept hero) */
    object-position: 50% 30%;
    filter: grayscale(15%) contrast(1.03) brightness(1.05);
  }
  .book-portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--ng-magenta-600) 10%, transparent);
    mix-blend-mode: multiply;
    pointer-events: none;
  }
</style>
