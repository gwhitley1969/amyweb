---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import logo from '../assets/brand/needle-girlie-logo-on-black.png';
---

<BaseLayout
  title="Needle Girlie | Medical Aesthetics in Harrisburg, NC"
  description="Needle Girlie — the medical-aesthetics practice of Amy Palacios, FNP, in Harrisburg, NC. The site is under construction."
>
  <section class="flex min-h-dvh flex-col items-center justify-center gap-8 px-6 text-center">
    <Image
      src={logo}
      alt="Needle Girlie"
      widths={[460, 924]}
      sizes="(max-width: 700px) 90vw, 640px"
      class="w-full max-w-[640px]"
      loading="eager"
      fetchpriority="high"
    />
    <div class="w-full max-w-[640px]">
      <div class="caution-tape" aria-hidden="true"></div>
      <h1 class="my-6 text-3xl font-bold uppercase tracking-[0.2em] sm:text-4xl">
        Under construction
      </h1>
      <div class="caution-tape" aria-hidden="true"></div>
    </div>
    <p class="max-w-prose text-balance">
      Pardon our dust — the full Needle Girlie experience is being built.
    </p>
    <p class="max-w-prose text-balance">
      The dedicated home of Amy Palacios, FNP — medical aesthetics in
      Harrisburg, NC.
    </p>
  </section>
</BaseLayout>

<style>
  .caution-tape {
    height: 2rem;
    border-top: 1px solid #f9a8d4;
    border-bottom: 1px solid #f9a8d4;
    background: repeating-linear-gradient(
      45deg,
      #ec4899,
      #ec4899 24px,
      #000 24px,
      #000 48px
    );
  }
</style>
