---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ChevronRun from '../components/ChevronRun.astro';
import { siteConfig } from '../lib/siteConfig';
// Transparent lockup rendered at 4x from the canonical HTML source
// (src/assets/brand/source/). Alpha background so the neon-hum glow
// traces the artwork silhouette, not a rectangle; renders identically
// on the noir page. Art untouched.
import logo from '../assets/brand/needle-girlie-lockup-alpha.png';
---

<BaseLayout
  title="Needle Girlie | Medical Aesthetics in Harrisburg, NC"
  description="Needle Girlie — the medical-aesthetics practice of Amy Palacios, FNP, in Harrisburg, NC. The site is under construction."
  surface="noir"
>
  <section class="flex min-h-dvh flex-col items-center justify-center gap-8 px-6 text-center">
    <Image
      src={logo}
      alt="Needle Girlie"
      widths={[480, 800, 1200, 1879]}
      sizes="(max-width: 820px) 94vw, 780px"
      class="neon-hum w-full max-w-[780px]"
      loading="eager"
      fetchpriority="high"
    />
    {/* neon marquee: the chase points visitors down toward the phone number */}
    <div class="marquee" aria-hidden="true">
      <ChevronRun variant="seam" chase />
    </div>
    <div class="w-full max-w-[640px]">
      <div class="caution-tape" aria-hidden="true"></div>
      <h1 class="my-6 text-3xl font-bold uppercase tracking-[0.2em] sm:text-4xl">
        Under construction
      </h1>
      <div class="caution-tape" aria-hidden="true"></div>
    </div>
    <p class="max-w-prose text-balance">
      Pardon the dust — the full Needle Girlie experience is being built.
    </p>
    <p class="max-w-prose text-balance">
      The dedicated home of Amy Palacios, FNP — medical aesthetics in
      Harrisburg, NC.
    </p>
    <p class="max-w-prose">
      Call for an appointment:
      <a href={siteConfig.phoneTel} class="font-semibold text-[#F9A8D4] underline underline-offset-4">
        {siteConfig.phone}
      </a>
    </p>
  </section>
</BaseLayout>

<style>
  /* marquee scale for this page only (the seam's default is content-column
   * sized; here it is a centerpiece under the sign) */
  .marquee :global(.chevron-run--seam) {
    height: 2rem;
  }
  .caution-tape {
    height: 2rem;
    border-top: 1px solid #f9a8d4;
    border-bottom: 1px solid #f9a8d4;
    background: repeating-linear-gradient(
      45deg,
      #ec4899,
      #ec4899 24px,
      #000 24px,
      #000 48px
    );
  }
</style>
