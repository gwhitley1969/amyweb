---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/siteConfig';
// Derivative of the operator-supplied logo: blank border cropped but with a
// black margin kept so the baked-in glow fades out inside the image (art
// untouched). Native art is only ~400px wide — browser upscaling is
// acceptable for the interim placeholder; Phase B needs hi-res exports.
import logo from '../assets/brand/needle-girlie-logo-on-black-trimmed.png';
---

<BaseLayout
  title="Needle Girlie | Medical Aesthetics in Harrisburg, NC"
  description="Needle Girlie — the medical-aesthetics practice of Amy Palacios, FNP, in Harrisburg, NC. The site is under construction."
>
  <section class="flex min-h-dvh flex-col items-center justify-center gap-8 px-6 text-center">
    <Image
      src={logo}
      alt="Needle Girlie"
      class="w-full max-w-[780px]"
      loading="eager"
      fetchpriority="high"
    />
    <div class="w-full max-w-[640px]">
      <div class="caution-tape" aria-hidden="true"></div>
      <h1 class="my-6 text-3xl font-bold uppercase tracking-[0.2em] sm:text-4xl">
        Under construction
      </h1>
      <div class="caution-tape" aria-hidden="true"></div>
    </div>
    <p class="max-w-prose text-balance">
      Pardon our dust — the full Needle Girlie experience is being built.
    </p>
    <p class="max-w-prose text-balance">
      The dedicated home of Amy Palacios, FNP — medical aesthetics in
      Harrisburg, NC.
    </p>
    <p class="max-w-prose">
      Call for an appointment:
      <a href={siteConfig.phoneTel} class="font-semibold text-[#F9A8D4] underline underline-offset-4">
        {siteConfig.phone}
      </a>
    </p>
  </section>
</BaseLayout>

<style>
  .caution-tape {
    height: 2rem;
    border-top: 1px solid #f9a8d4;
    border-bottom: 1px solid #f9a8d4;
    background: repeating-linear-gradient(
      45deg,
      #ec4899,
      #ec4899 24px,
      #000 24px,
      #000 48px
    );
  }
</style>
