---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaricatureWindow from '../components/CaricatureWindow.astro';
import { siteConfig } from '../lib/siteConfig';
// Derivative of the original Claude-designed logo, rendered at 4x from the
// canonical HTML source (src/assets/brand/source/) and cropped with a black
// margin so the glow fades out inside the image. Art untouched.
import logo from '../assets/brand/needle-girlie-logo-on-black-trimmed.png';
// Commissioned caricature of Amy in the studio — the "she's inside getting
// it ready" moment (docs/superpowers/specs/2026-07-09-caricature-*.md).
import caricature from '../assets/brand/amy-caricature.png';
---

<BaseLayout
  title="Needle Girlie | Medical Aesthetics in Harrisburg, NC"
  description="Needle Girlie — the medical-aesthetics practice of Amy Palacios, FNP, in Harrisburg, NC. The site is under construction."
  surface="noir"
>
  <section class="flex min-h-dvh flex-col items-center gap-8 px-6 py-12 text-center">
    <Image
      src={logo}
      alt="Needle Girlie"
      widths={[480, 800, 1560]}
      sizes="(max-width: 820px) 94vw, 780px"
      class="construction-sign w-full max-w-[780px]"
      loading="eager"
      fetchpriority="high"
    />
    <CaricatureWindow
      image={caricature}
      alt="Illustrated caricature of Amy Palacios, FNP, seated on a studio counter"
      taped
      class="w-full max-w-[520px]"
    />
    <div class="max-w-prose">
      <h1 class="text-3xl font-bold uppercase tracking-[0.2em] sm:text-4xl">
        Under construction
      </h1>
      <p class="lead mt-3 text-balance text-pink-tint">
        Amy's inside, getting the studio ready.
      </p>
    </div>
    <p class="max-w-prose text-balance">
      The dedicated home of Amy Palacios, FNP — medical aesthetics in
      Harrisburg, NC.
    </p>
    <p class="max-w-prose">
      Call for an appointment:
      <a href={siteConfig.phoneTel} class="font-semibold text-[#F9A8D4] underline underline-offset-4">
        {siteConfig.phone}
      </a>
    </p>
    <p class="mt-auto text-xs">
      Created by: <a
        href="https://xtend-ai.com"
        class="underline underline-offset-4"
        target="_blank"
        rel="noopener"
        aria-label="Xtend-AI (opens in new tab)">Xtend-AI</a>
    </p>
  </section>
</BaseLayout>

<style is:global>
  /* The sign performs its approved routine (styleguide-verified,
   * docs/DECISIONS.md 2026-07-08): ignite once on load, then hum forever.
   * Keyframes + reduced-motion handling live in global.css. */
  .construction-sign {
    animation:
      ng-ignite 1.8s ease-out 0.4s 1 backwards,
      ng-hum 3.2s ease-in-out 2.2s infinite;
  }
</style>
