---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TreatmentLayout from '../../layouts/TreatmentLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceLineGrid from '../../components/ServiceLineGrid.astro';
import LocationCard from '../../components/LocationCard.astro';
import GetTheApp from '../../components/GetTheApp.astro';
import DisclaimerBlock from '../../components/DisclaimerBlock.astro';
import InvestigationalNotice from '../../components/InvestigationalNotice.astro';
import BioteDisclaimer from '../../components/BioteDisclaimer.astro';
import DraftBanner from '../../components/DraftBanner.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AtAGlance from '../../components/AtAGlance.astro';
import VisitSteps from '../../components/VisitSteps.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import TrustChips from '../../components/TrustChips.astro';
import { siteConfig } from '../../lib/siteConfig';
import tokensRaw from '../../styles/tokens.css?raw';
import ConceptHome from '../../components/ConceptHome.astro';

// Preview-only (approved design plan): production builds emit no styleguide.
export function getStaticPaths() {
  if (import.meta.env.PUBLIC_ENV === 'production') return [];
  return [
    { params: { all: undefined } },
    { params: { all: 'treatment-demo' } },
    { params: { all: 'concept' } },
  ];
}

const { all } = Astro.params;
const isTreatmentDemo = all === 'treatment-demo';
const isConcept = all === 'concept';

// Demo-only editorial Q&A (real FAQ copy is Phase C, clinician-approved).
const demoFaq = [
  {
    q: 'Do I need a consultation first?',
    a: 'No — book directly whenever you are ready. A free consultation is available on request if you would like to talk anything through first.',
  },
  {
    q: 'How do I book?',
    a: `Call ${siteConfig.phone} to schedule an appointment.`,
  },
];

// Swatch hexes are parsed from tokens.css at BUILD time (?raw import) so
// they can never drift from the real declarations; only the role strings
// are styleguide editorial. Comments are stripped before matching so hex
// mentions in the contrast table never leak in. Zero JS ships.
const tokenHexes = new Map(
  [
    ...tokensRaw
      .replace(/\/\*[\s\S]*?\*\//g, '')
      .matchAll(/(--ng-[\w-]+):\s*(#[0-9a-fA-F]{6})/g),
  ].map((m) => [m[1], m[2].toUpperCase()]),
);
const roles: Record<string, string> = {
  '--ng-neon-500': 'the neon — static aura color, dark only, never text',
  '--ng-pink-500': 'wordmark pink — graphics; large text on noir',
  '--ng-magenta-600':
    'edge rules + display-accent text on light (never a fill behind white text)',
  '--ng-pink-300': 'tints; body text + accent on noir',
  '--ng-blush-50': 'card tint + accent bands on the paper ambient',
  '--ng-ink-pink': 'links + button fills on light',
  '--ng-ink-900': 'body text on light',
  '--ng-paper': 'the ambient light surface (page background)',
  '--ng-noir': 'dark surfaces (the sign)',
};
const swatches = Object.entries(roles)
  .filter(([name]) => tokenHexes.has(name))
  .map(([name, role]) => ({ name, hex: tokenHexes.get(name), role }));
---

{
  isConcept ? (
    <ConceptHome />
  ) : isTreatmentDemo ? (
    <TreatmentLayout
      title="Sample Treatment Line"
      summary="A demonstration of the treatment template with placeholder copy, shown in its unapproved (draft) state."
      products={['Sample Product A', 'Sample Product B']}
      ctaType="consult"
      investigational={true}
      investigationalProduct="Sample Product B"
      bioteDisclaimer={true}
      pricingDisplay="consult"
      clinicianApproved={false}
      faq={demoFaq}
      seo={{
        title: 'Treatment template demo | Needle Girlie styleguide',
        description: 'Preview-only demonstration of the treatment page template.',
      }}
    >
      <p class="mt-6">
        Body copy flows here in Phase C, drafted from the BUILD_SPEC §7 briefs: what it is, who it
        is generally for, individualized under clinician supervision.
      </p>
    </TreatmentLayout>
  ) : (
    <BaseLayout
      title="Styleguide | Needle Girlie"
      description="Preview-only design-system reference for needlegirlie.com."
    >
      <Header slot="header" />

      <div class="mx-auto max-w-6xl space-y-16 px-6 py-12">
        <section>
          <h1 class="display-2">Styleguide</h1>
          <p class="lead mt-4">
            Preview-only reference for the design system — "serious glamour" direction
            (DECISIONS 2026-07-18). Also see the
            <a href="/styleguide/treatment-demo" class="underline underline-offset-4" style="color: var(--ng-link)">
              treatment template demo</a>.
          </p>
        </section>

      </div>

      {/* The sign leads with its STATIC aura — the composed remainder of
          the neon identity (ignite/hum retired, DECISIONS 2026-07-18).
          The image-led hero also keeps the initial viewport free of
          font-swap reflow (CI CLS root cause, PR #4). Promise line:
          operator/Amy-selected 2026-07-08 (replaced "signed with a kiss"
          per Amy). Final wording re-confirmed in Phase C. */}
      <Hero promise="Medical aesthetics, made personal.">
        <CTAButton variant="book" href="#" />
        <CTAButton variant="call" />
      </Hero>

      <div class="mx-auto max-w-6xl space-y-16 px-6 py-12">
        <section>
          <h2 class="heading-2">Motion</h2>
          <p class="mt-4">
            All CSS, all stilled under reduced-motion. The sign above <em>breathes</em> —
            a slow, deep aura swell, always alive when you look at it. The big noir
            accent phrases <em>shimmer</em> with a soft neon halo (the noir line below
            shows it). Content <em>rises</em> into place as it enters the viewport (the
            effect scrubs with the scroll and replays on re-entry — this section
            demonstrates it as you arrive, and the cards and steps further down do the
            same), hairline rules <em>trace</em> in under section openers, and button
            chevrons <em>nudge</em> on hover or tap. The glow that moves lives in exactly
            two places: the sign and the accent phrase.
          </p>
          <div class="mt-8">
            <p class="eyebrow">Section opener</p>
            <hr class="rule-accent ng-trace mt-2" />
            <p class="ng-rise mt-4 max-w-prose">
              The opener signature: an eyebrow, a traced accent rule, and copy that
              settles into place. Scroll this out of view and back to replay it.
            </p>
          </div>
        </section>

        <section>
          <h2 class="heading-2">Palette</h2>
          <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
            {swatches.map((s) => (
              <div class="border border-pink-tint/40 p-3">
                <div class="h-14 w-full border border-ink/10" style={`background:${s.hex}`} />
                <p class="mt-2 font-mono text-xs">{s.name}</p>
                <p class="font-mono text-xs">{s.hex}</p>
                <p class="mt-1 text-xs">{s.role}</p>
              </div>
            ))}
          </div>
        </section>

        <section>
          <h2 class="heading-2">Type scale</h2>
          <div class="mt-6 space-y-4">
            <p class="display-0">Display 0 — Playfair 76</p>
            <p class="display-1">Display 1 — Playfair 61</p>
            <p class="display-2">Display 2 — Playfair 49</p>
            <p class="heading-2">Heading 2 — Playfair 39</p>
            <p class="heading-3">Heading 3 — DM Sans 31</p>
            <p class="heading-4">Heading 4 — DM Sans 25</p>
            <p class="lead">Lead — DM Sans 20</p>
            <p>Body — DM Sans 16, line-height 1.6.</p>
            <p class="eyebrow">Eyebrow — DM Sans 13, tracked caps</p>
          </div>
          <p class="mt-4">
            Display weights are 500 with tight tracking; display-0 is the home hero only,
            applied responsively (display-2 md:display-0).
          </p>
        </section>

        <section>
          <h2 class="heading-2">Two-tone display headline</h2>
          <p class="mt-4">
            Accent span for display sizes (≥39px) only — magenta on light, pink-300 on noir
            (tokens.css contrast table).
          </p>
          <p class="heading-2 mt-6">
            Quietly glamorous, <span class="display-accent">entirely personal</span>
          </p>
          <div class="surface mt-6 p-6" data-surface="noir">
            <p class="heading-2">
              Quietly glamorous, <span class="display-accent ng-shimmer">entirely personal</span>
            </p>
          </div>
        </section>

        <section>
          <h2 class="heading-2">CTA buttons</h2>
          <div class="mt-6 flex flex-wrap items-center gap-4">
            <CTAButton variant="book" href="#" />
            <CTAButton variant="consult" href="#" />
            <CTAButton variant="call" />
          </div>
          <div class="surface mt-6 flex flex-wrap items-center gap-4 p-6" data-surface="noir">
            <CTAButton variant="book" href="#" />
            <CTAButton variant="consult" href="#" />
            <CTAButton variant="call" />
          </div>
        </section>

        <section>
          <h2 class="heading-2">Service-line grid</h2>
          <div class="mt-6">
            <ServiceLineGrid />
          </div>
        </section>

        <section class="grid gap-6 sm:grid-cols-2">
          <LocationCard />
          <GetTheApp />
        </section>

        <section>
          <h2 class="heading-2">At a glance</h2>
          <p class="mt-4">Fact card injected near the top of every treatment page.</p>
          <div class="mt-6 max-w-2xl">
            <AtAGlance />
          </div>
        </section>

        <section>
          <h2 class="heading-2">Visit steps</h2>
          <p class="mt-4">Process-only walkthrough injected on every treatment page.</p>
          <div class="mt-6 max-w-2xl">
            <VisitSteps />
          </div>
        </section>

        <section>
          <h2 class="heading-2">FAQ accordion</h2>
          <p class="mt-4">
            Native <code>&lt;details&gt;</code>, zero JS. Editorial Q&amp;A only — compliance text
            never goes inside an accordion.
          </p>
          <div class="mt-6 max-w-2xl">
            <FaqAccordion items={demoFaq} />
          </div>
        </section>

        <section>
          <h2 class="heading-2">Trust line</h2>
          <p class="mt-4">
            Credential and process facts only — an editorial middot-separated line, on both
            surfaces.
          </p>
          <div class="mt-6">
            <TrustChips />
          </div>
          <div class="surface mt-6 p-6" data-surface="noir">
            <TrustChips />
          </div>
        </section>

        <section>
          <h2 class="heading-2">Compliance blocks</h2>
          <div class="mt-6 space-y-6">
            <DraftBanner />
            <InvestigationalNotice productName="Sample Product" />
            <BioteDisclaimer />
            <DisclaimerBlock />
          </div>
        </section>

        <section>
          <h2 class="heading-2">Breadcrumbs</h2>
          <div class="mt-6">
            <Breadcrumbs
              items={[
                { name: 'Home', href: '/' },
                { name: 'Services', href: '/services' },
                { name: 'Current page', href: '#' },
              ]}
            />
          </div>
        </section>
      </div>

      <Footer slot="footer" />
    </BaseLayout>
  )
}
